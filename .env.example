# --- Paperless connection ---
# Base URL of your Paperless-ngx instance.
PAPERLESS_BASE_URL=http://paperless.local
# API token used with "Authorization: Token <token>".
PAPERLESS_API_TOKEN=your_token_here

# --- Core storage backends ---
# SQLAlchemy DB URL for local intelligence data (documents, suggestions, audit, OCR layers).
DATABASE_URL=postgres://paperless:changeme@127.0.0.1:5432/paperless_intelligence
# Active vector store provider ("qdrant" or "weaviate").
VECTOR_STORE_PROVIDER=qdrant
# Optional generic vector-store URL override. For Weaviate this is derived from WEAVIATE_HTTP_* if unset.
VECTOR_STORE_URL=
# Optional generic vector-store API key override. For Weaviate this falls back to WEAVIATE_API_KEY if unset.
VECTOR_STORE_API_KEY=
# Optional generic primary vector collection override.
VECTOR_STORE_COLLECTION=
# Optional generic centroid/doc-similarity collection override.
VECTOR_STORE_CENTROID_COLLECTION=
# Qdrant base URL (internal service URL or LAN URL).
QDRANT_URL=http://127.0.0.1:6333
# Optional Qdrant API key (leave empty if disabled).
QDRANT_API_KEY=
# Qdrant collection name used for chunk embeddings (legacy/default when VECTOR_STORE_PROVIDER=qdrant).
QDRANT_COLLECTION=paperless_chunks

# --- Weaviate vector store ---
# HTTP host for the official Weaviate client (required when VECTOR_STORE_PROVIDER=weaviate).
WEAVIATE_HTTP_HOST=
# HTTP port for Weaviate REST/management traffic.
WEAVIATE_HTTP_PORT=8080
# Use HTTPS for Weaviate HTTP traffic (1=on, 0=off).
WEAVIATE_HTTP_SECURE=0
# Optional dedicated gRPC host (defaults to WEAVIATE_HTTP_HOST if unset).
WEAVIATE_GRPC_HOST=
# gRPC port used by the official Weaviate client.
WEAVIATE_GRPC_PORT=50051
# Use TLS for Weaviate gRPC traffic (1=on, 0=off).
WEAVIATE_GRPC_SECURE=0
# Optional Weaviate API key.
WEAVIATE_API_KEY=
# Main collection for chunk embeddings.
WEAVIATE_COLLECTION=paperless_chunks
# Separate collection for centroid/doc-similarity vectors (defaults to <WEAVIATE_COLLECTION>_centroids if unset).
WEAVIATE_CENTROID_COLLECTION=

# --- Queue / worker ---
# Enable Redis queue processing (1=on, 0=off).
QUEUE_ENABLED=0
# Redis host[:port] for queue and worker coordination.
REDIS_HOST=127.0.0.1:6379
# Worker retry count for retryable failures (timeout/rate-limit/network/qdrant).
WORKER_MAX_RETRIES=2

# --- LLM endpoints and models ---
# Default OpenAI-compatible base URL for chat/extraction/embeddings unless overridden below.
LLM_BASE_URL=http://llm.local:8080
# Optional API key for LLM provider.
LLM_API_KEY=
# Master key for encrypting live runtime provider API-key overrides stored in the DB.
# Must be a valid Fernet key, not arbitrary text.
# PowerShell example:
#   $key = [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
#   $key.Replace('+','-').Replace('/','_')
# Python example:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
RUNTIME_SETTINGS_MASTER_KEY=
# Main reasoning/extraction model.
TEXT_MODEL=gpt-oss:20b
# Optional chat-specific model override (fallback: TEXT_MODEL).
CHAT_MODEL=
# Embedding model used for vectorization.
EMBEDDING_MODEL=qwen3-embedding
# Number of chunks embedded per request (if backend supports batch input).
EMBEDDING_BATCH_SIZE=8
# Timeout per embedding request in seconds.
EMBEDDING_TIMEOUT_SECONDS=45
# Hard cap of chunks per document (0 = unlimited).
EMBEDDING_MAX_CHUNKS_PER_DOC=800
# Max tokens sent in a single embedding input (safety split guard).
EMBEDDING_MAX_INPUT_TOKENS=3000
# Optional verbose LLM logging (1=on).
# LLM_DEBUG=1
# LLM_DEBUG_FULL_RESPONSE=1  # logs full untruncated model responses (can be very large)

# --- OCR routing and scoring model endpoints ---
# Base URL for OCR quality scoring/chat-style calls.
OCR_CHAT_BASE=http://llm.local:8080
# Base URL for OCR vision/layout calls.
OCR_VISION_BASE=http://llm.local:8080
# Optional dedicated model for OCR quality scoring (fallback: TEXT_MODEL).
OCR_SCORE_MODEL=

# --- Sync / embedding behavior ---
# Auto-create embeddings during sync (1=on, 0=manual enqueue).
EMBED_ON_SYNC=0
# Chunking strategy for embedding ingestion (currently "heuristic").
CHUNK_MODE=heuristic
# Max characters per chunk before splitting.
CHUNK_MAX_CHARS=1200
# Overlap characters between adjacent chunks.
CHUNK_OVERLAP=200
# Similarity threshold used in chunk/group logic.
CHUNK_SIMILARITY_THRESHOLD=0.75

# --- Text extraction / vision OCR toggles ---
# Enable PDF page text fallback extraction when Paperless OCR page splits are unavailable.
ENABLE_PDF_PAGE_EXTRACT=1
# Enable optional second OCR pass via vision model.
ENABLE_VISION_OCR=0

# --- HTTP / TLS ---
# Verify TLS certificates for outgoing HTTP requests (set 0 for internal/self-signed setups).
HTTPX_VERIFY_TLS=1
# Structured logging controls.
LOG_LEVEL=INFO
LOG_JSON=0
# Log API requests slower than this threshold in ms (0 disables slow-request logging).
API_SLOW_REQUEST_LOG_MS=1200

# --- Suggestion pipeline ---
# Enable extra suggestion debug output (1=on).
SUGGESTIONS_DEBUG=0
# Prompt file path for normalized suggestions generation.
SUGGESTIONS_PROMPT_PATH=backend/app/prompts/suggestions.txt
# Max characters fed into a suggestions LLM request.
SUGGESTIONS_MAX_INPUT_CHARS=9000
# Page-count threshold to switch to hierarchical processing.
LARGE_DOC_PAGE_THRESHOLD=20
# Page notes call timeout and output budget.
PAGE_NOTES_TIMEOUT_SECONDS=35
PAGE_NOTES_MAX_OUTPUT_TOKENS=220
# Section/global summary aggregation budgets.
SUMMARY_SECTION_PAGES=12
SECTION_SUMMARY_MAX_INPUT_TOKENS=3500
SECTION_SUMMARY_TIMEOUT_SECONDS=60
GLOBAL_SUMMARY_MAX_INPUT_TOKENS=4500
GLOBAL_SUMMARY_TIMEOUT_SECONDS=90
SUMMARY_MAX_OUTPUT_TOKENS=700

# --- Vision OCR model and limits ---
# Vision model name used for second OCR pass.
VISION_MODEL=qwen2.5-vl
# Resize cap for longest image side before OCR.
VISION_OCR_MAX_DIM=1024
# Optional fixed target size (0 keeps adaptive behavior).
VISION_OCR_TARGET_DIM=0
# Number of PDF pages processed per OCR request (1 is safest for large docs).
VISION_OCR_BATCH_PAGES=1
# Reject OCR text if non-alnum ratio exceeds this value.
VISION_OCR_MAX_NONALNUM_RATIO=0.6
# Max pages per document for vision OCR (0 = no explicit cap).
VISION_OCR_MAX_PAGES=0
# Minimum extracted chars required to accept OCR result.
VISION_OCR_MIN_CHARS=40
# Minimum quality score required to keep OCR page result.
VISION_OCR_MIN_SCORE=60
# Optional inline OCR prompt override (empty uses prompt file).
VISION_OCR_PROMPT=
# Prompt file path for vision OCR.
VISION_OCR_PROMPT_PATH=backend/app/prompts/vision_ocr.txt
# Timeout per OCR request in seconds.
VISION_OCR_TIMEOUT_SECONDS=120

# Worker budget for joining page text before suggestions.
WORKER_SUGGESTIONS_MAX_CHARS=9000
# Safety switch for real Paperless writeback execution (0 = disabled, dry-run only).
WRITEBACK_EXECUTE_ENABLED=0

# --- OCR quality scoring thresholds and limits ---
# "Bad" OCR threshold (higher score = worse noise).
OCR_THRESH_BAD=55
# "Borderline" OCR threshold.
OCR_THRESH_BORDERLINE=32
# Include optional logprob/perplexity component in OCR scoring (1=on).
OCR_ENABLE_LOGPROB_PPL=1
# Max chars sent to OCR PPL scoring prompt.
OCR_PPL_MAX_PROMPT_CHARS=20000
# Chunk size for OCR PPL scoring.
OCR_PPL_CHUNK_CHARS=4000
# Timeout for OCR PPL scoring calls (seconds).
OCR_PPL_TIMEOUT_SEC=120
# Timeout for vision OCR calls (seconds).
OCR_VISION_TIMEOUT_SEC=180
# Max tokens for OCR vision responses.
OCR_VISION_MAX_TOKENS=1200

# --- Status / SSE stream ---
# SSE status stream update interval in seconds.
STATUS_STREAM_INTERVAL_SECONDS=5
# TTL for caching LLM /v1/models checks in status stream (seconds).
STATUS_LLM_MODELS_TTL_SECONDS=60
# Max unique citation pages to resolve in evidence pass.
EVIDENCE_MAX_PAGES=3
# Minimum snippet length required before evidence resolution is attempted.
EVIDENCE_MIN_SNIPPET_CHARS=20
