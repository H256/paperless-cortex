# --- Worker-specific environment ---
# Keep queue enabled for dedicated worker containers.
QUEUE_ENABLED=1
# Redis host[:port] used for queue and worker lock/heartbeat.
REDIS_HOST=redis

# SQLAlchemy DB URL for local intelligence data.
DATABASE_URL=postgresql+psycopg://paperless:paperless@postgres:5432/paperless_intelligence
# Qdrant base URL for embeddings read/write.
QDRANT_URL=http://qdrant:6333

# Base OpenAI-compatible endpoint (used unless OCR overrides are set).
LLM_BASE_URL=http://llm:8080
# Optional API key for LLM provider.
LLM_API_KEY=
# Main reasoning/extraction model used for suggestions and chat tasks.
TEXT_MODEL=gpt-oss:20b
# Vision model for second OCR pass.
VISION_MODEL=qwen2.5-vl
# Embedding model for vectorization.
EMBEDDING_MODEL=nomic-embed-text
# Number of chunks embedded per request (if backend supports batch input).
EMBEDDING_BATCH_SIZE=16
# Timeout per embedding request in seconds.
EMBEDDING_TIMEOUT_SECONDS=60
# Hard cap of chunks per document (0 = unlimited).
EMBEDDING_MAX_CHUNKS_PER_DOC=0

# Paperless endpoint and API token used by worker tasks.
PAPERLESS_BASE_URL=
PAPERLESS_API_TOKEN=

# Optional dedicated endpoints for OCR quality and vision OCR.
OCR_CHAT_BASE=http://llm:8080
OCR_VISION_BASE=http://llm:8080
# Optional dedicated OCR scoring model (fallback: TEXT_MODEL).
OCR_SCORE_MODEL=

# OCR quality score thresholds (higher score = worse OCR quality).
OCR_THRESH_BAD=55
OCR_THRESH_BORDERLINE=32
# Enable logprob/perplexity component for OCR quality scoring.
OCR_ENABLE_LOGPROB_PPL=1
# Input and timeout limits for OCR quality scoring.
OCR_PPL_MAX_PROMPT_CHARS=20000
OCR_PPL_CHUNK_CHARS=4000
OCR_PPL_TIMEOUT_SEC=120
# Vision OCR runtime limits.
OCR_VISION_TIMEOUT_SEC=180
OCR_VISION_MAX_TOKENS=1200
# Max chars fed into a suggestions LLM request.
SUGGESTIONS_MAX_INPUT_CHARS=12000
# Page-count threshold to switch to hierarchical processing.
LARGE_DOC_PAGE_THRESHOLD=20
# Page notes call timeout and output budget.
PAGE_NOTES_TIMEOUT_SECONDS=45
PAGE_NOTES_MAX_OUTPUT_TOKENS=300
# Section/global summary aggregation budgets.
SUMMARY_SECTION_PAGES=25
SECTION_SUMMARY_MAX_INPUT_TOKENS=6000
SECTION_SUMMARY_TIMEOUT_SECONDS=90
GLOBAL_SUMMARY_MAX_INPUT_TOKENS=7000
GLOBAL_SUMMARY_TIMEOUT_SECONDS=120
SUMMARY_MAX_OUTPUT_TOKENS=900
# Number of PDF pages processed per OCR request (1 is safest for large docs).
VISION_OCR_BATCH_PAGES=1
# Worker budget for joining page text before suggestions.
WORKER_SUGGESTIONS_MAX_CHARS=12000

# Status stream tuning.
STATUS_STREAM_INTERVAL_SECONDS=5
STATUS_LLM_MODELS_TTL_SECONDS=60
